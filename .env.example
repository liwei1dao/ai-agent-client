# AI Agent Client 环境配置示例
# 复制此文件为 .env 并填入真实值（.env 已加入 .gitignore，不会提交）

# OpenAI / 兼容 API
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# Azure Speech (STT + TTS)
AZURE_SPEECH_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_SPEECH_REGION=eastasia

# 阿里云 STT
ALIYUN_STT_APP_KEY=xxxxxxxxxx
ALIYUN_STT_TOKEN=xxxxxxxxxx

# 豆包 STT
DOUBAO_STT_APP_ID=xxxxxxxxxx
DOUBAO_STT_TOKEN=xxxxxxxxxx

# DeepL 翻译
DEEPL_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:fx

# 阿里云翻译
ALIYUN_TRANSLATE_ACCESS_KEY_ID=xxxxxxxxxx
ALIYUN_TRANSLATE_ACCESS_KEY_SECRET=xxxxxxxxxx
