# AI Agent Client — 环境配置示例
# 复制此文件为 .env，填入真实 Key（.env 已被 .gitignore 忽略）

# ── STT（语音识别）──────────────────────────────────
AZURE_STT_KEY=your_azure_speech_key
AZURE_STT_REGION=eastus

ALIYUN_STT_KEY=your_aliyun_stt_access_key
GOOGLE_STT_KEY=your_google_stt_api_key
DOUBAO_STT_KEY=your_doubao_stt_key

# ── TTS（语音合成）──────────────────────────────────
AZURE_TTS_KEY=your_azure_speech_key
AZURE_TTS_REGION=eastus

ALIYUN_TTS_KEY=your_aliyun_tts_access_key
DOUBAO_TTS_KEY=your_doubao_tts_key

# ── LLM（大语言模型）────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

COZE_API_KEY=your_coze_api_key

# ── STS（端到端语音，豆包）──────────────────────────
DOUBAO_STS_KEY=your_doubao_sts_key
DOUBAO_STS_APP_ID=your_doubao_sts_app_id

# ── Translation（翻译）─────────────────────────────
DEEPL_API_KEY=your_deepl_api_key
# 阿里云格式：accessKeyId:accessKeySecret
ALIYUN_TRANSLATION_KEY=your_id:your_secret
GOOGLE_TRANSLATE_KEY=your_google_translate_key
